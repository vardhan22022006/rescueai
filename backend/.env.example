DATABASE_URL=sqlite:///./rescueai.db
ENVIRONMENT=development

# Optional: OpenWeatherMap API Key (get free at https://openweathermap.org/api)
# Leave empty to use mock data - app works without any API keys!
OPENWEATHER_API_KEY=

# Translation backend for non-English disaster reports.
# "argos"  (default) — runs fully offline, no key, auto-downloads language models.
# "google"           — uses deep-translator free tier (pip install deep-translator==1.11.4).
TRANSLATE_BACKEND=argos
